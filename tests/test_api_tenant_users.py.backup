"""テナントユーザー管理APIのテスト"""
import pytest
from fastapi.testclient import TestClient
from unittest.mock import AsyncMock, MagicMock, patch
from datetime import datetime
from app.main import app
from app.models.tenant_user import TenantUser
from app.api.tenant_users import get_tenant_user_service


@pytest.fixture
def client():
    """FastAPIテストクライアント"""
    return TestClient(app)


@pytest.fixture
def mock_tenant_user_service():
    """モックTenantUserService"""
    mock = MagicMock()
    mock.invite_user = AsyncMock()
    mock.list_tenant_users = AsyncMock()
    mock.remove_user = AsyncMock()
    return mock


class TestInviteUserAPI:
    """POST /tenants/{tenant_id}/users のテスト"""

    class Test正常系:
        """正常系テスト"""

        def test_should_invite_user_successfully(self, client, mock_tenant_user_service, sample_tenant_user, mock_auth_service_user_response):
            """ユーザー招待が成功する（201 Created）"""
            # Arrange: リクエストデータを準備
            request_data = {"userId": "user_456"}
            mock_tenant_user_service.invite_user.return_value = sample_tenant_user
            app.dependency_overrides[get_tenant_user_service] = lambda: mock_tenant_user_service
            
            with patch('app.api.tenant_users.AuthServiceClient') as mock_auth_client_class:
                mock_auth_client_instance = MagicMock()
                mock_auth_client_instance.get_user_details = AsyncMock(return_value=mock_auth_service_user_response)
                mock_auth_client_class.return_value = mock_auth_client_instance
                
                # Act: APIを呼び出し
                response = client.post("/api/v1/tenants/tenant_test/users", json=request_data)
            
            # Assert: 201が返る
            assert response.status_code == 201
            app.dependency_overrides.clear()

        def test_should_return_tenant_user_with_user_details(self, client, mock_tenant_user_service, sample_tenant_user, mock_auth_service_user_response):
            """ユーザー詳細を含むTenantUserを返す"""
            # Arrange: リクエストデータを準備
            request_data = {"userId": "user_123"}
            mock_tenant_user_service.invite_user.return_value = sample_tenant_user
            app.dependency_overrides[get_tenant_user_service] = lambda: mock_tenant_user_service
            
            with patch('app.api.tenant_users.AuthServiceClient') as mock_auth_client_class:
                mock_auth_client_instance = MagicMock()
                mock_auth_client_instance.get_user_details = AsyncMock(return_value=mock_auth_service_user_response)
                mock_auth_client_class.return_value = mock_auth_client_instance
                
                # Act: APIを呼び出し
                response = client.post("/api/v1/tenants/tenant_test/users", json=request_data)
            
            # Assert: userDetailsが含まれる
            assert response.status_code == 201
            data = response.json()
            assert "userDetails" in data
            assert data["userDetails"]["id"] == "user_123"
            app.dependency_overrides.clear()

    class Test異常系:
        """異常系テスト"""

        def test_should_return_404_when_tenant_not_found(self, client, mock_tenant_user_service):
            """テナントが存在しない場合に404を返す"""
            # Arrange
            request_data = {"userId": "user_123"}
            mock_tenant_user_service.invite_user.side_effect = ValueError("Tenant tenant_notfound not found")
            app.dependency_overrides[get_tenant_user_service] = lambda: mock_tenant_user_service
            
            # Act
            response = client.post("/api/v1/tenants/tenant_notfound/users", json=request_data)
            
            # Assert
            assert response.status_code == 404
            app.dependency_overrides.clear()

        def test_should_return_404_when_user_not_found(self, client, mock_tenant_user_service):
            """ユーザーが存在しない場合に404を返す"""
            # Arrange
            request_data = {"userId": "user_notfound"}
            mock_tenant_user_service.invite_user.side_effect = ValueError("User user_notfound not found")
            app.dependency_overrides[get_tenant_user_service] = lambda: mock_tenant_user_service
            
            # Act
            response = client.post("/api/v1/tenants/tenant_test/users", json=request_data)
            
            # Assert
            assert response.status_code == 404
            app.dependency_overrides.clear()

        def test_should_return_409_when_user_already_member(self, client, mock_tenant_user_service):
            """ユーザーが既にメンバーの場合に409を返す"""
            # Arrange
            request_data = {"userId": "user_123"}
            mock_tenant_user_service.invite_user.side_effect = ValueError("User is already a member")
            app.dependency_overrides[get_tenant_user_service] = lambda: mock_tenant_user_service
            
            # Act
            response = client.post("/api/v1/tenants/tenant_test/users", json=request_data)
            
            # Assert
            assert response.status_code == 409
            app.dependency_overrides.clear()

        def test_should_return_400_when_max_users_exceeded(self, client, mock_tenant_user_service):
            """最大ユーザー数超過時に400を返す"""
            # Arrange
            request_data = {"userId": "user_123"}
            mock_tenant_user_service.invite_user.side_effect = ValueError("Maximum user limit reached")
            app.dependency_overrides[get_tenant_user_service] = lambda: mock_tenant_user_service
            
            # Act
            response = client.post("/api/v1/tenants/tenant_test/users", json=request_data)
            
            # Assert
            assert response.status_code == 400
            app.dependency_overrides.clear()

        def test_should_return_503_when_auth_service_unavailable(self, client, mock_tenant_user_service):
            """認証サービス不可時に503を返す"""
            # Arrange
            request_data = {"userId": "user_123"}
            mock_tenant_user_service.invite_user.side_effect = RuntimeError("Auth service unavailable")
            app.dependency_overrides[get_tenant_user_service] = lambda: mock_tenant_user_service
            
            # Act
            response = client.post("/api/v1/tenants/tenant_test/users", json=request_data)
            
            # Assert
            assert response.status_code == 503
            app.dependency_overrides.clear()

        def test_should_return_500_on_unexpected_error(self, client, mock_tenant_user_service):
            """予期しないエラー時に500を返す"""
            # Arrange
            request_data = {"userId": "user_123"}
            mock_tenant_user_service.invite_user.side_effect = Exception("Unexpected error")
            app.dependency_overrides[get_tenant_user_service] = lambda: mock_tenant_user_service
            
            # Act
            response = client.post("/api/v1/tenants/tenant_test/users", json=request_data)
            
            # Assert
            assert response.status_code == 500
            app.dependency_overrides.clear()


class TestListTenantUsersAPI:
    """GET /tenants/{tenant_id}/users のテスト"""

    class Test正常系:
        """正常系テスト"""

        def test_should_list_tenant_users_successfully(self, client, mock_tenant_user_service):
            """テナントユーザー一覧を取得できる（200 OK）"""
            # Arrange
            mock_result = {
                "data": [
                    {
                        "id": "tenant_user_tenant_test_user_123",
                        "tenant_id": "tenant_test",
                        "user_id": "user_123",
                        "assigned_at": datetime(2026, 2, 1, 10, 0, 0),
                        "assigned_by": "user_admin_001"
                    }
                ],
                "pagination": {
                    "skip": 0,
                    "limit": 20,
                    "hasMore": False
                }
            }
            mock_tenant_user_service.list_tenant_users.return_value = mock_result
            app.dependency_overrides[get_tenant_user_service] = lambda: mock_tenant_user_service
            
            # Act
            response = client.get("/api/v1/tenants/tenant_test/users")
            
            # Assert
            assert response.status_code == 200
            data = response.json()
            assert "data" in data
            assert "pagination" in data
            app.dependency_overrides.clear()

        def test_should_return_pagination_info(self, client, mock_tenant_user_service):
            """ページネーション情報を含む"""
            # Arrange
            mock_result = {
                "data": [],
                "pagination": {
                    "skip": 0,
                    "limit": 20,
                    "hasMore": False
                }
            }
            mock_tenant_user_service.list_tenant_users.return_value = mock_result
            app.dependency_overrides[get_tenant_user_service] = lambda: mock_tenant_user_service
            
            # Act
            response = client.get("/api/v1/tenants/tenant_test/users")
            
            # Assert
            assert response.status_code == 200
            data = response.json()
            assert "pagination" in data
            assert "skip" in data["pagination"]
            assert "limit" in data["pagination"]
            assert "hasMore" in data["pagination"]
            app.dependency_overrides.clear()

        def test_should_include_total_when_requested(self, client, mock_tenant_user_service):
            """include_total=trueの場合にtotalを含む"""
            # Arrange
            mock_result = {
                "data": [],
                "pagination": {
                    "skip": 0,
                    "limit": 20,
                    "hasMore": False,
                    "total": 0
                }
            }
            mock_tenant_user_service.list_tenant_users.return_value = mock_result
            app.dependency_overrides[get_tenant_user_service] = lambda: mock_tenant_user_service
            
            # Act
            response = client.get("/api/v1/tenants/tenant_test/users?include_total=true")
            
            # Assert
            assert response.status_code == 200
            data = response.json()
            assert "total" in data["pagination"]
            app.dependency_overrides.clear()

    class Test境界値:
        """境界値テスト"""

        def test_should_accept_limit_100(self, client, mock_tenant_user_service):
            """limit=100を受け入れる"""
            # Arrange
            mock_result = {
                "data": [],
                "pagination": {
                    "skip": 0,
                    "limit": 100,
                    "hasMore": False
                }
            }
            mock_tenant_user_service.list_tenant_users.return_value = mock_result
            app.dependency_overrides[get_tenant_user_service] = lambda: mock_tenant_user_service
            
            # Act
            response = client.get("/api/v1/tenants/tenant_test/users?limit=100")
            
            # Assert
            assert response.status_code == 200
            app.dependency_overrides.clear()

        def test_should_reject_limit_over_100(self, client):
            """limit>100を拒否する（400 Bad Request）"""
            # Act
            response = client.get("/api/v1/tenants/tenant_test/users?limit=101")
            
            # Assert
            assert response.status_code == 400
            assert "exceed" in response.json()["detail"].lower()

        def test_should_reject_negative_skip(self, client):
            """skip<0を拒否する（400 Bad Request）"""
            # Act
            response = client.get("/api/v1/tenants/tenant_test/users?skip=-1")
            
            # Assert
            assert response.status_code == 400
            assert "non-negative" in response.json()["detail"].lower()

    class Test異常系:
        """異常系テスト"""

        def test_should_return_500_on_unexpected_error(self, client, mock_tenant_user_service):
            """予期しないエラー時に500を返す"""
            # Arrange
            mock_tenant_user_service.list_tenant_users.side_effect = Exception("Unexpected error")
            app.dependency_overrides[get_tenant_user_service] = lambda: mock_tenant_user_service
            
            # Act
            response = client.get("/api/v1/tenants/tenant_test/users")
            
            # Assert
            assert response.status_code == 500
            app.dependency_overrides.clear()


class TestRemoveUserAPI:
    """DELETE /tenants/{tenant_id}/users/{user_id} のテスト"""

    class Test正常系:
        """正常系テスト"""

        def test_should_remove_user_successfully(self, client, mock_tenant_user_service):
            """ユーザー削除が成功する（204 No Content）"""
            # Arrange
            mock_tenant_user_service.remove_user.return_value = None
            app.dependency_overrides[get_tenant_user_service] = lambda: mock_tenant_user_service
            
            # Act
            response = client.delete("/api/v1/tenants/tenant_test/users/user_123")
            
            # Assert
            assert response.status_code == 204
            app.dependency_overrides.clear()

    class Test異常系:
        """異常系テスト"""

        def test_should_return_404_when_tenant_user_not_found(self, client, mock_tenant_user_service):
            """TenantUserが存在しない場合に404を返す"""
            # Arrange
            mock_tenant_user_service.remove_user.side_effect = ValueError("TenantUser not found")
            app.dependency_overrides[get_tenant_user_service] = lambda: mock_tenant_user_service
            
            # Act
            response = client.delete("/api/v1/tenants/tenant_test/users/user_notfound")
            
            # Assert
            assert response.status_code == 404
            app.dependency_overrides.clear()

        def test_should_return_500_on_unexpected_error(self, client, mock_tenant_user_service):
            """予期しないエラー時に500を返す"""
            # Arrange
            mock_tenant_user_service.remove_user.side_effect = Exception("Unexpected error")
            app.dependency_overrides[get_tenant_user_service] = lambda: mock_tenant_user_service
            
            # Act
            response = client.delete("/api/v1/tenants/tenant_test/users/user_123")
            
            # Assert
            assert response.status_code == 500
            app.dependency_overrides.clear()

